int main()
{

    float matriz[3][3];
    
    for(int i = 0; i < 3; i++){
        for(int j = 0; j < 3; j++){
            scanf("%f", &matriz[i][j]);
        }
    }
    
    
    // Zerar A21
        for(int j = 0; j < 3; j++){
